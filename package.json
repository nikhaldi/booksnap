{
  "name": "react-native-booksnap",
  "version": "0.1.0",
  "description": "Extract text from a photo of a book page taken on a mobile device (Android, iOS, React Native)",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "setup": "pnpm install && bash android/test-harness/scripts/download-dictionaries.sh",
    "test": "vitest run",
    "test:android": "cd android/test-harness && ./gradlew cleanTestDebugUnitTest testDebugUnitTest"
  },
  "devDependencies": {
    "vitest": "^4.0.18",
    "typescript": "^5"
  },
  "keywords": [
    "react-native",
    "expo",
    "ocr",
    "book-scanning",
    "text-recognition",
    "document-scanning"
  ],
  "packageManager": "pnpm@9.15.4",
  "license": "MIT",
  "dependencies": {},
  "peerDependencies": {
    "expo": "*",
    "expo-modules-core": "*",
    "react": "*",
    "react-native": "*"
  }
}
