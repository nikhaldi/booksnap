{
  "name": "react-native-booksnap",
  "version": "0.1.0",
  "description": "Extract text from a photo of a book page taken on a mobile device (Android, iOS, React Native)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "setup": "pnpm install && bash android/test-harness/scripts/download-dictionaries.sh",
    "test": "vitest run",
    "test:android": "cd android/test-harness && ./gradlew cleanTestDebugUnitTest testDebugUnitTest",
    "test:ios": "bash ios/test-harness/scripts/run-tests.sh",
    "lint": "eslint src/",
    "lint:android": "bash android/scripts/ktlint.sh",
    "lint:ios": "bash ios/scripts/swiftlint.sh lint --strict",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "format:android": "bash android/scripts/ktlint.sh -F",
    "format:ios": "bash ios/scripts/swiftlint.sh lint --fix && bash ios/scripts/swiftlint.sh lint --strict",
    "dataset:pack": "bash -c 'tar -czf \"$1.tar.gz\" --exclude=.DS_Store -C datasets \"$1\"' --",
    "reports:deploy": "bash scripts/deploy-reports.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "react-native",
    "expo",
    "ocr",
    "book-scanning",
    "text-recognition",
    "document-scanning"
  ],
  "packageManager": "pnpm@9.15.4",
  "license": "MIT",
  "peerDependencies": {
    "expo": "*",
    "expo-modules-core": "*",
    "react": "*",
    "react-native": "*"
  }
}
